SLStreaming._StartLocalApp =3D function(info, params) {
    var iParams =3D 0;
    var newIP =3D [];
    var translation =3D {};
    if (info.initParams) {
        var pp =3D SLStreaming.ParseInitParams(info.initParams);
        for (var i =3D 0; i < pp.length; ++i) {
            var val =3D pp[i].value;
            if (val.substring(0, 10) =3D=3D "streaming:") {
                val =3D params[iParams++];
            }
            translation[pp[i].value] =3D val;
            if (pp[i].key) {
