    var ifn =3D manifest.loadFunction         || "";
    var stx =3D manifest.source               || "";
    var w   =3D manifest.width                || "100%";
    var h   =3D manifest.height               || "100%";
    var bg  =3D manifest.background           || "";
    var wl  =3D manifest.isWindowless         || "";
    var fr  =3D manifest.framerate            || "";
    var onl =3D manifest.onLoad               || "";
    var one =3D manifest.onError              || "";
    var eha =3D manifest.enableHtmlAccess     || "";
    var ipi =3D manifest.inPlaceInstallPrompt || "";
    var ver =3D manifest.version              || "1.0";

    if (appUrl =3D=3D null) {
