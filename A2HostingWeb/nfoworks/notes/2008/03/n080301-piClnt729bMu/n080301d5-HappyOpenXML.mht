    hash +=3D "/" + encodeURIComponent(appId);
    hash +=3D "/" + encodeURIComponent(stx);
    hash +=3D "/" + encodeURIComponent(bg);
    hash +=3D "/" + encodeURIComponent(wl);
    hash +=3D "/" + encodeURIComponent(fr);
    hash +=3D "/" + encodeURIComponent(onl);
    hash +=3D "/" + encodeURIComponent(one);
    hash +=3D "/" + encodeURIComponent(eha);
    hash +=3D "/" + encodeURIComponent(ipi);
    hash +=3D "/" + encodeURIComponent(ver);

