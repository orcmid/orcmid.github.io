                params.events.onLoad =3D window[params.events.onLoad];
            }
            if (params.events.onError) {
                params.events.onError =3D window[params.events.onError];
            }
            if (params.initParams) {
                params.initParams =3D params.initParams.toString();
            }
            //alert("eltName: " + eltName + ", appId: " + appId + ", =
appUrl: " + appUrl + ", rootXaml: " + rootXaml);
