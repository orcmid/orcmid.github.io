		else {
		//Added by Scott Hanselman
		ref =3D document.location.href;
		if (ref.indexOf('?') =3D=3D -1) return;
		}
	}
	qs =3D ref.substr(ref.indexOf('?')+1);
	qsa =3D qs.split('&');
	for (i=3D0;i<qsa.length;i++) {
		qsip =3D qsa[i].split('=3D');
