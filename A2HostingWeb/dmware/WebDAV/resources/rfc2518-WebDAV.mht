  <P><PRE>   &lt;?xml version=3D"1.0" encoding=3D"utf-8" ?&gt;
   &lt;D:lockinfo xmlns:D=3D"DAV:"&gt;
     &lt;D:locktype&gt;&lt;D:write/&gt;&lt;/D:locktype&gt;
     &lt;D:lockscope&gt;&lt;D:exclusive/&gt;&lt;/D:lockscope&gt;
     &lt;D:owner&gt;
          &lt;D:href&gt;<A =
href=3D"http://www.ics.uci.edu/~ejw/contact.html</D:href">http://www.ics.=
uci.edu/~ejw/contact.html</D:HREF< a>&gt;
     &lt;/D:owner&gt;
   &lt;/D:lockinfo&gt;
</PRE>
  <P>&gt;&gt;Response=20
  <P></P>
