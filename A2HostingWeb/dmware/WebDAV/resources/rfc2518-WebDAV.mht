   &lt;D:multistatus xmlns:D=3D"DAV:"&gt;
     &lt;D:response&gt;
          &lt;D:href&gt;<A =
href=3D"http://webdav.sb.aol.com/webdav/secret</D:href">http://webdav.sb.=
aol.com/webdav/secret</D:HREF< a>&gt;
          &lt;D:status&gt;HTTP/1.1 403 Forbidden&lt;/D:status&gt;
     &lt;/D:response&gt;
     &lt;D:response&gt;
          &lt;D:href&gt;<A =
href=3D"http://webdav.sb.aol.com/webdav/</D:href">http://webdav.sb.aol.co=
m/webdav/</D:HREF< a>&gt;
          &lt;D:propstat&gt;
               &lt;D:prop&gt;&lt;D:lockdiscovery/&gt;&lt;/D:prop&gt;
               &lt;D:status&gt;HTTP/1.1 424 Failed =
Dependency&lt;/D:status&gt;
          &lt;/D:propstat&gt;
