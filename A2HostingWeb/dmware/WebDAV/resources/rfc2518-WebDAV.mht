  <BR>Timeout: Infinite, Second-4100000000 <BR>If:=20
  (&lt;opaquelocktoken:e71d4fae-5dec-22d6-fea5-00a0c91e6be4&gt;) =
Authorization:=20
  Digest username=3D"ejw", <BR>realm=3D"ejw@webdav.sb.aol.com", =
nonce=3D"...",=20
  <BR>uri=3D"/workspace/webdav/proposal.doc", <BR>response=3D"...", =
opaque=3D"..."=20
  <P>&gt;&gt;Response=20
  <P>HTTP/1.1 200 OK <BR>Content-Type: text/xml; charset=3D"utf-8"=20
  <BR>Content-Length: xxxx=20
  <P><PRE>   &lt;?xml version=3D"1.0" encoding=3D"utf-8" ?&gt;
   &lt;D:prop xmlns:D=3D"DAV:"&gt;
     &lt;D:lockdiscovery&gt;
          &lt;D:activelock&gt;
               &lt;D:locktype&gt;&lt;D:write/&gt;&lt;/D:locktype&gt;
</PRE>
  <P></P>
  <DT>
  <HR>

  <DD>
  <DT><EM><A name=3Dpage-50>Page 50</A></EM>
  <DD>
  <P><PRE>               =
&lt;D:lockscope&gt;&lt;D:exclusive/&gt;&lt;/D:lockscope&gt;
               &lt;D:depth&gt;Infinity&lt;/D:depth&gt;
               &lt;D:owner&gt;
                    &lt;D:href&gt;
                    <A =
href=3D"http://www.ics.uci.edu/~ejw/contact.html">http://www.ics.uci.edu/=
~ejw/contact.html</A>
                    &lt;/D:href&gt;
               &lt;/D:owner&gt;
               &lt;D:timeout&gt;Second-604800&lt;/D:timeout&gt;
               &lt;D:locktoken&gt;
